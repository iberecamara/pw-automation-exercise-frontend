{
  "name": "pw-automation-exercise",
  "version": "1.0.0",
  "description": "Vanilla Playwright Test Automation Framework targeting https://automationexercise.com",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test --config=src/configs/playwright.config.ts",
    "test:ui": "npx playwright test --ui --config=src/configs/playwright.config.ts",
    "test:smoke": "npx playwright test --grep \"(?=.*@smoke)\" --config=src/configs/playwright.config.ts",
    "test:ui:smoke": "npx playwright test --ui --grep \"(?=.*@smoke)\" --config=src/configs/playwright.config.ts",
    "test:sanity": "npx playwright test --grep \"(?=.*@sanity)\" --config=src/configs/playwright.config.ts",
    "test:ui:sanity": "npx playwright test --ui --grep \"(?=.*@sanity)\" --config=src/configs/playwright.config.ts",
    "report:generate": "npx allure generate ./artifacts/reports/allure/allure-results -o ./artifacts/reports/allure/allure-report",
    "report:open": "npx allure open ./artifacts/reports/allure/allure-report",
    "report:export": "allure awesome generate ./artifacts/reports/allure/allure-results -o ./artifacts/reports/allure/allure-report-single --single-file",
    "report": "npm run report:generate && npm run report:open",
    "clean": "rimraf artifacts"
  },
